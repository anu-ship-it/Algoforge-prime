REDIS_HOST=judge0_redis
REDIS_PORT=6379

POSTGRES_HOST=judge0_db
POSTGRES_PORT=5432
POSTGRES_DB=judge0
POSTGRES_USER=judge0
POSTGRES_PASSWORD=judge0_secret

RAILS_ENV=production

# Execution limits per submission
CPU_TIME_LIMIT=5
CPU_EXTRA_TIME=1
WALL_TIME_LIMIT=10
MEMORY_LIMIT=128000
STACK_LIMIT=64000
MAX_PROCESSES_AND_OR_THREADS=30

# File size limit (KB)
MAX_FILE_SIZE=1024

# Security — no network access from inside user code
ALLOW_ENABLE_NETWORK=false

# Queue
ENABLE_BATCHED_SUBMISSIONS=true
MAX_QUEUE_SIZE=100