NODE_ENV=development
PORT=4000

# PostgreSQL
DATABASE_URL=postgres://algoforge:algoforge_secret@postgres:5432/algofrge

# Redis
REDIS_URL=redis://:redis_secret@redis:6379

# Ollama (local LLM)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# Judge0 (code execution)
JUDGE0_URL=http://judge0:2358

# JWT - change these before any public deployment
JWT_SECRET=change_this_to_a_random_64_char_string_in_production
JWT_REFRESH_SECRET=change_this_to_another_random_6_char_string_in_production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# CORS
CORS_ORIGIN=http://localhost:3000